{
  "mcpServers": {
    "context7": {
      "type": "http",
      "url": "http://localhost:3338/mcp"
    },
    "browser-mcp": {
      "type": "http",
      "url": "http://localhost:3336/mcp"
    },
    "github-mcp": {
      "type": "http",
      "url": "http://localhost:3344/",
      "headers": {
        "Authorization": "Bearer {{github token}}}"
      }
    },
    "chrome-devtools": {
      "type": "stdio",
      "command": "npx",
      "args": ["-y", "chrome-devtools-mcp@latest", "--no-usage-statistics"]
    }
  }
}